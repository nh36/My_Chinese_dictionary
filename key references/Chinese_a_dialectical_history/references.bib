@article{bybee_grammatical_2017,
	title = {Grammatical and lexical factors in sound change: {A} usage-based approach},
	volume = {29},
	issn = {0954-3945, 1469-8021},
	shorttitle = {Grammatical and lexical factors in sound change},
	url = {https://www.cambridge.org/core/product/identifier/S0954394517000199/type/journal_article},
	doi = {10.1017/S0954394517000199},
	abstract = {The question of whether or not grammatical factors can condition or block sound change has been discussed from many perspectives for more than a century without resolution (Melchert, 1975). Here we consider studies of sound change in progress which show that words or phrases that are used frequently in the phonetic environment for change undergo the change before those whose use is less frequent in these contexts. Because words of different categories and with different structures also have different distributions, they may occur preferentially in certain phonetic environments. Thus, some apparent cases of influence by grammatical and lexical factors can be explained by phonetic factors if we expand our notion of phonetic environment to include frequency within the environment for change, which includes the segmental environment as well as factors that affect the degree of prominence a word receives in context.},
	language = {en},
	number = {3},
	urldate = {2023-12-20},
	journal = {Language Variation and Change},
	author = {Bybee, Joan},
	month = oct,
	year = {2017},
	pages = {273--300},
}

