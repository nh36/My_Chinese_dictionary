@article{niyazov_open_2016,
	title = {Open access meets discoverability: {Citations} to articles posted to academia.edu},
	volume = {11},
	url = {http://dx.doi.org/10.1371%2Fjournal.pone.0148257},
	doi = {10.1371/journal.pone.0148257},
	abstract = {{\textless}p{\textgreater}Using matching and regression analyses, we measure the difference in citations between articles posted to Academia.edu and other articles from similar journals, controlling for field, impact factor, and other variables. Based on a sample size of 31,216 papers, we find that a paper in a median impact factor journal uploaded to Academia.edu receives 16\% more citations after one year than a similar article not available online, 51\% more citations after three years, and 69\% after five years. We also found that articles also posted to Academia.edu had 58\% more citations than articles only posted to other online venues, such as personal and departmental home pages, after five years.{\textless}/p{\textgreater}},
