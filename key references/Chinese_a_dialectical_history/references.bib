@article{delancey_non-singular_2019,
	title = {Non-singular pronouns in {Tibeto}-{Burman} ({Trans}-{Himalayan})},
	volume = {42},
	issn = {0731-3500, 2214-5907},
	url = {http://www.jbe-platform.com/content/journals/10.1075/ltba.18006.del},
	doi = {10.1075/ltba.18006.del},
	abstract = {Abstract
            
              This paper surveys the forms of dual and plural pronouns across the Tibeto-Burman languages, and offers a reconstruction of the non-singular pronouns, and a general account of how various branches and languages have diverged from this original system. We can certainly reconstruct two, perhaps three, person-number portmanteaus: \#
              i
              1
              pl
              , or perhaps 1
              pl.inc
              , \#
              ni
              2
              pl
              , and, less certainly, \#
              ka
              1
              pl.exc
              . We also reconstruct \#
              tsi
              dual
              which combined with singular pronouns to make dual forms. This construction was the model on which most daughter languages have innovated an analytic system of person and number marking, with distinct person and dual and/or plural morphemes combining to make the morphologically complex but semantically transparent compositional forms found in the majority of languages.},
	language = {en},
	number = {1},
	urldate = {2024-01-11},
	journal = {Linguistics of the Tibeto-Burman Area},
	author = {DeLancey, Scott},
	month = jun,
	year = {2019},
	pages = {110--136},
}

@article{delancey_evidence_2019,
	title = {Evidence for {Inland} {Penutian}},
	volume = {60},
	issn = {1944-6527},
	url = {https://muse.jhu.edu/article/727008},
	doi = {10.1353/anl.2019.0000},
	abstract = {Comparative evidence for the Penutian hypothesis is very thin, but more evidence has been presented in the literature for the validity of two smaller units: Plateau Penutian, consisting of Sahaptian, Cayuse, KlamathModoc, and probably Maiduan, and Yok-Utian, consisting of Yokuts and MiwokCostanoan. However, some evidence for a genetic relationship between these two units are provided here. Several lexical comparisons are presented that involve correspondences in internal word structure, larger word families, or both. Two morphological comparisons, of a locative construction and a numeral suffix, help to explain irregularities in the daughter languages.},
	language = {en},
	number = {2},
	urldate = {2024-01-11},
	journal = {Anthropological Linguistics},
	author = {DeLancey, Scott},
	year = {2019},
	pages = {95--109},
}

@article{delancey_hierarchical_2018,
	title = {Hierarchical and accusative alignment of {Verbal} {Person} {Marking} in {Trans}-{Himalayan}},
	volume = {4},
	issn = {2196-078X, 2196-0771},
	url = {https://www.degruyter.com/document/doi/10.1515/jsall-2017-0003/html},
	doi = {10.1515/jsall-2017-0003},
	abstract = {Verbal Person Marking is a neglected feature of Trans-Himalayan (Sino-Tibetan) languages. TH systems are of great typological interest, showing both canonical versions and unusual variations of both hierarchical and accusative alignment. The predominant and ancestral pattern is hierarchical, but we also see innovative accusative patterns. Canonical hierarchical and accusative systems do occur, but a majority of VPM systems of both alignments show variations on the basic patterns. Hierarchical systems sometimes develop means to index both participants in a transitive configuration rather than only the higher. Accusative systems frequently develop secondary O indexation for SAP arguments, and sometimes move further in the direction of hierarchical patterning. Thus Trans-Himalayan offers a wealth of examples of VPM systems, which deserve greater attention from the field of typology.},
	language = {en},
	number = {1},
	urldate = {2024-01-11},
	journal = {Journal of South Asian Languages and Linguistics},
	author = {DeLancey, Scott},
	month = oct,
	year = {2018},
	pages = {85--105},
}

