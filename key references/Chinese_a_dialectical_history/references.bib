@article{humphries_network_2008,
	title = {Network ‘{Small}-{World}-{Ness}’: {A} {Quantitative} {Method} for {Determining} {Canonical} {Network} {Equivalence}},
	volume = {3},
	url = {http://dx.plos.org/10.1371%2Fjournal.pone.0002051},
	doi = {10.1371/journal.pone.0002051},
	abstract = {{\textless}sec{\textgreater}{\textless}title{\textgreater}Background{\textless}/title{\textgreater}{\textless}p{\textgreater}Many technological, biological, social, and information networks fall into the broad class of ‘small-world’ networks: they have tightly interconnected clusters of nodes, and a shortest mean path length that is similar to a matched random graph (same number of nodes and edges). This semi-quantitative definition leads to a categorical distinction (‘small/not-small’) rather than a quantitative, continuous grading of networks, and can lead to uncertainty about a network's small-world status. Moreover, systems described by small-world networks are often studied using an equivalent canonical network model – the Watts-Strogatz (WS) model. However, the process of establishing an equivalent WS model is imprecise and there is a pressing need to discover ways in which this equivalence may be quantified.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}{\textless}sec{\textgreater}{\textless}title{\textgreater}Methodology/Principal Findings{\textless}/title{\textgreater}{\textless}p{\textgreater}We defined a precise measure of ‘small-world-ness’ {\textless}italic{\textgreater}S{\textless}/italic{\textgreater} based on the trade off between high local clustering and short path length. A network is now deemed a ‘small-world’ if {\textless}italic{\textgreater}S{\textless}/italic{\textgreater}\&gt;1 - an assertion which may be tested statistically. We then examined the behavior of {\textless}italic{\textgreater}S{\textless}/italic{\textgreater} on a large data-set of real-world systems. We found that all these systems were linked by a linear relationship between their {\textless}italic{\textgreater}S{\textless}/italic{\textgreater} values and the network size {\textless}italic{\textgreater}n{\textless}/italic{\textgreater}. Moreover, we show a method for assigning a unique Watts-Strogatz (WS) model to any real-world network, and show analytically that the WS models associated with our sample of networks also show linearity between {\textless}italic{\textgreater}S{\textless}/italic{\textgreater} and {\textless}italic{\textgreater}n{\textless}/italic{\textgreater}. Linearity between {\textless}italic{\textgreater}S{\textless}/italic{\textgreater} and {\textless}italic{\textgreater}n{\textless}/italic{\textgreater} is not, however, inevitable, and neither is {\textless}italic{\textgreater}S{\textless}/italic{\textgreater} maximal for an arbitrary network of given size. Linearity may, however, be explained by a common limiting growth process.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}{\textless}sec{\textgreater}{\textless}title{\textgreater}Conclusions/Significance{\textless}/title{\textgreater}{\textless}p{\textgreater}We have shown how the notion of a small-world network may be quantified. Several key properties of the metric are described and the use of WS canonical models is placed on a more secure footing.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}},
	number = {4},
	journal = {PLoS ONE},
	author = {Humphries, Mark D. and Gurney, Kevin},
	month = apr,
	year = {2008},
	note = {Publisher: Public Library of Science},
	pages = {e0002051},
}

