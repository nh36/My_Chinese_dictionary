@article{bialek_organisation_2021,
	title = {The organisation of stage stations in {Central} {Asian} colonial provinces of the {Tibetan} {Empire} according to {Pelliot} tibétain 1096r},
	volume = {31},
	issn = {1356-1863, 1474-0591},
	url = {https://www.cambridge.org/core/product/identifier/S1356186321000316/type/journal_article},
	doi = {10.1017/S1356186321000316},
	abstract = {Based on the first English translation of the Old Tibetan document with the shelf mark Pelliot tibétain  recto, the article analyses the internal organisation of a stage station (sluṅs) in the Central Asian colonial provinces of the Tibetan Empire. It examines officials and offices that constituted a stage station, as well as persons who were using its services. By comparing the information contained in the document with later reports of foreign travellers, the article reconstructs the organisation of a stage station. It also brings to light certain traits that were apparently common to the first historically attested relay system of the Tibetan Empire and the succeeding system introduced by the Mongols during the thirteenth century CE.},
