@phdthesis{dempsey_reconsideration_1995,
	type = {{PhD} {Thesis}},
	title = {A {Reconsideration} of {Some} {Phonoiogical} {Issues} {Involved} in {Reconstructing} {Sino}-{Tibetan} {Numerals}},
	abstract = {The Sino-Tibetan language family, consisting of Sinitic (Chinese) and the Tibeto-Burman group, is one of the largest in the world, but unlike the similarly extensive Inda-European group, a large-scale scholarly debate on the underlying phonological processes which connect all the ST (SinoTibetan) languages has barely begun, yet scholars writing papers on Chinese historical linguistics have begun to frequently quote suggested TB (Tibeto-Burman) cognates, and a recent book on Tibetan grammar refers off handedly to controversial, hypothetical reconstructions as if they were established reality. Dictionaries of individual TB languages quote TB protoforms which have either been since revised or which never were subjec t to confirmation by other investigators. The pioneering work of one or two scholars has been viewed on a par with results which took over a century to achieve in the Inda-European field. This dissertation suggests some alternate views of the phonological hfit:ory of the ST group. It mainly concentrates on the history of Chinese, Tibetan and Burmese since these are the oldest documented languages in the group, but also includes extensive data from several hundred other languages and dialects. Ancient loan-relationships with Hmong-Mien and Tai-Kadi languages are also discussed. The discussion focuses on the set of basic numerals shared by most of these languages but also treats other items of basic vocabulary which share phonological developments with some of the numerals. Large-scale cognate tables are provided for each numeral, with suggested genetic and geographic affiliations. As much as possible, data from the original sources has been reanalysed and standardised for the sake of comparison.},
	school = {University of Washington},
	author = {Dempsey, Jakob},
	year = {1995},
}

